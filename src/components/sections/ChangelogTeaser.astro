---
import { siteLinks } from '../../config/site-links';
---

<section class="section" id="changelog" data-reveal aria-labelledby="changelog-title">
	<div class="section__inner">
		<h2 id="changelog-title" class="section__title">Changelog</h2>
		<p class="section__lead">High-signal updates as we ship improvements to APIs, MCPs, and developer tooling.</p>
		<ul class="changelog-list">
			<li><span class="mono">2026-03-01</span> — Developer hub scaffold and navigation model</li>
			<li><span class="mono">2026-02-15</span> — Hosting MCP preview channels</li>
			<li><span class="mono">2026-02-01</span> — ConvesioPay webhook refinements</li>
		</ul>
		<p style="margin-top: 1.25rem">
			<a class="btn btn--secondary" href={siteLinks.changelog.href}>{siteLinks.changelog.label}</a>
		</p>
	</div>
</section>
