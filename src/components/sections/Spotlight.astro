---
import { siteLinks } from '../../config/site-links';
---

<section class="section" id="featured-apis" data-reveal aria-labelledby="spotlight-title">
	<div class="section__inner">
		<h2 id="spotlight-title" class="section__title">Featured APIs</h2>
		<!--
		<p class="section__lead">
			A nice description goes here.
		</p>
		-->
		<div class="spotlight-grid">
			<article class="spotlight spotlight--coral" id="spotlight-pay">
				<h3 class="card__title">ConvesioPay</h3>
				<p class="card__text">
					Enterprise-grade payments with developer-friendly flows—designed to pair with your commerce stack on
					Convesio.
				</p>
				<a
					class="btn btn--primary"
					href={siteLinks.spotlight.convesioPay.href}
					{...(siteLinks.spotlight.convesioPay.external
						? { target: '_blank', rel: 'noopener noreferrer' }
						: {})}
				>
					{siteLinks.spotlight.convesioPay.label}
				</a>
			</article>
			<article class="spotlight spotlight--turquoise" id="spotlight-convert">
				<h3 class="card__title">ConvesioConvert</h3>
				<p class="card__text">
					Omni-channel marketing automation for WooCommerce and Shopify in your commerce stack.
					 
				</p>
				<a
					class="btn btn--secondary"
					href={siteLinks.spotlight.convert.href}
					{...(siteLinks.spotlight.convert.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
				>
					{siteLinks.spotlight.convert.label}
				</a>
			</article>
		</div>
	</div>
</section>
